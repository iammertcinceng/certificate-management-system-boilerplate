  "help": {
    "title": "Help Center",
    "subtitle": "Find answers to frequently asked questions",
    "faqTitle": "Frequently Asked Questions",
    "quickLinks": {
      "verify": {
        "title": "Verify Certificate",
        "description": "Quickly verify any certificate"
      },
      "contact": {
        "title": "Contact Support",
        "description": "Get in touch with our team"
      },
      "howItWorks": {
        "title": "How It Works",
        "description": "Learn about our process"
      }
    },
    "faqs": {
      "0": {
        "question": "How do I verify a certificate?",
        "answer": "You can verify a certificate by entering the certificate number or national ID on our verification page. The system will instantly show you the certificate details and validity status."
      },
      "1": {
        "question": "How long does it take to issue a certificate?",
        "answer": "Certificate issuance is typically instant once all required approvals are obtained. The approval process may vary depending on your institution's settings and partner requirements."
      },
      "2": {
        "question": "Can I download certificates in bulk?",
        "answer": "Yes, institutions can download multiple certificates at once using our bulk download feature available in the certificate management panel."
      },
      "3": {
        "question": "What security measures are in place?",
        "answer": "We use bank-level encryption, blockchain technology for certificate verification, and comply with international data protection standards including GDPR and KVKK."
      },
      "4": {
        "question": "How do I become a partner institution?",
        "answer": "You can register as an institution through our registration page. After verification, you'll have access to all certificate management features."
      },
      "5": {
        "question": "What payment methods do you accept?",
        "answer": "We accept various payment methods including credit cards, bank transfers, and institutional invoicing. Contact us for enterprise payment options."
      }
    },
    "contactCta": {
      "title": "Still have questions?",
      "subtitle": "Our support team is ready to help you",
      "button": "Contact Us"
    }
  },
  "privacy": {
    "title": "Privacy Policy",
    "lastUpdated": "Last Updated",
    "sections": {
      "intro": {
        "title": "Introduction",
        "content": "This Privacy Policy explains how Mert CIN Certificate Authorisation collects, uses, and protects your personal information. We are committed to ensuring your privacy and protecting your data."
      },
      "dataCollection": {
        "title": "Data We Collect",
        "content": "We collect the following types of information:",
        "items": {
          "0": "Personal identification information (name, email, phone number)",
          "1": "Certificate and training related data",
          "2": "Usage data and analytics",
          "3": "Technical information (IP address, browser type, device information)"
        }
      },
      "dataUsage": {
        "title": "How We Use Your Data",
        "content": "Your data is used to provide and improve our services, process certificates, communicate with you, and ensure platform security. We never sell your personal information to third parties."
      },
      "dataSecurity": {
        "title": "Data Security",
        "content": "We implement industry-standard security measures including encryption, secure servers, and regular security audits to protect your information from unauthorized access, alteration, or disclosure."
      },
      "userRights": {
        "title": "Your Rights",
        "content": "You have the right to access, correct, delete, or export your personal data. You can also object to certain data processing activities. Contact us to exercise these rights."
      },
      "contact": {
        "title": "Contact Us",
        "content": "If you have any questions about this Privacy Policy, please contact us at"
      }
    }
  },
  "terms": {
    "title": "Terms of Use",
    "lastUpdated": "Last Updated",
    "sections": {
      "acceptance": {
        "title": "Acceptance of Terms",
        "content": "By accessing and using this platform, you accept and agree to be bound by these Terms of Use. If you do not agree to these terms, please do not use our services."
      },
      "services": {
        "title": "Description of Services",
        "content": "Mert CIN Certificate Authorisation provides a digital platform for certificate issuance, verification, and management. We reserve the right to modify or discontinue services at any time."
      },
      "userResponsibilities": {
        "title": "User Responsibilities",
        "content": "Users are responsible for:",
        "items": {
